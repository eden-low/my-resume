# EdenAtlas — environment variable names for Netlify Functions.
#
# This file documents NAMES ONLY. It contains no working values and is safe to commit.
# Do NOT put real secrets here, in netlify.toml, in any frontend .js file, in assistant.html/
# assistant.js, in any HTML page, in Firestore, in git history, in error messages, or in logs —
# every one of those is either readable by anyone who loads the site or ends up somewhere this
# repo's history is kept.
#
# Real values belong in exactly one place: Netlify → Site/Project configuration → Environment
# variables (per deploy context, e.g. "Production" vs "Deploy previews", if the values should
# differ). Netlify Functions read them server-side via process.env — they are never bundled into
# anything the browser downloads. Every Function in netlify/functions/ (assistant.js, weather.js)
# fails closed (HTTP 500, no details leaked) if any variable it requires is missing at request
# time.

# --- Qwen (Alibaba Cloud Model Studio) — powers the Owner-only Atlas Assistant ---
# Provider identifier. Not a secret; literal value shown here is the actual configured provider.
AI_PROVIDER=qwen
# DashScope API key. Secret — Model Studio console → API Keys. Never logged, never echoed in
# any Function response, never printed by this repo's own code under any error path.
DASHSCOPE_API_KEY=replace_me
# No default is hardcoded anywhere in this codebase on purpose: silently falling back to a
# billable production model would be a real cost/behavior surprise. netlify/functions/lib/
# qwen.js requires this to be set and fails closed otherwise. "qwen-plus" is documented here
# only as a commonly-used starting point, not as a default value the code will assume.
QWEN_MODEL=qwen-plus
# The full OpenAI-compatible Chat Completions base URL for your Model Studio region (e.g. the
# Singapore/international endpoint) — kept entirely environment-controlled, never hardcoded in
# any committed file, because it embeds your actual Workspace ID. Do not include the trailing
# "/chat/completions" segment — the code appends that itself.
QWEN_BASE_URL=replace_me

# --- Firebase Admin SDK (server-side only; bypasses Firestore/Storage Security Rules, so it
#     must never be used from the browser and never committed as a file — see .gitignore's
#     service-account*.json / firebase-adminsdk-*.json rules) ---
FIREBASE_PROJECT_ID=replace_me
# Paste the *contents* of a service-account JSON key as a single-line value via the Netlify UI
# (not a file path, not a filename) — never commit the service-account JSON file itself.
FIREBASE_SERVICE_ACCOUNT=replace_me

# --- CORS / origin allowlist for Netlify Functions ---
# Comma-separated if you ever need more than one production origin; local dev origins
# (Netlify Dev, a plain static server) are already handled in code and don't need to be listed
# here — see netlify/functions/assistant.js's LOCAL_DEV_ORIGINS.
ALLOWED_ORIGIN=https://edenatlas.netlify.app

# --- OpenWeatherMap — powers netlify/functions/weather.js (Production Hardening Phase 1) ---
# Placeholder name only, no working value (per this file's own policy above). home.html and
# me.js previously called OpenWeatherMap directly from the browser with a key hardcoded in each
# file's own source — readable via view-source and permanently present in this repo's git
# history regardless of any later edit. That is a DIFFERENT, already-compromised key from the
# one that belongs here: this variable is for a NEW key generated after that old one is revoked/
# rotated in the OpenWeatherMap dashboard (never reuse the exposed value). Read server-side only
# by netlify/functions/weather.js; never included in any Function response, error message, or
# log line it produces.
OPENWEATHER_API_KEY=replace_me
