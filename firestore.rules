rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /photos/{photoId} {
      allow read: if resource.data.visibility == 'public'
                  || (request.auth != null && (
                       request.auth.token.email == 'jjun8647@gmail.com'
                       || exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email))
                     ));
      allow write: if request.auth != null && request.auth.token.email == 'jjun8647@gmail.com';
    }
    match /expenses/{expenseId} {
      allow read: if resource.data.visibility == 'public'
                  || (request.auth != null && (
                       request.auth.token.email == 'jjun8647@gmail.com'
                       || exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email))
                     ));
      allow write: if request.auth != null && request.auth.token.email == 'jjun8647@gmail.com';
    }
    match /journals/{journalId} {
      allow read: if resource.data.visibility == 'public'
                  || (request.auth != null && (
                       request.auth.token.email == 'jjun8647@gmail.com'
                       || exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email))
                     ));
      allow write: if request.auth != null && request.auth.token.email == 'jjun8647@gmail.com';
    }
    match /life_events/{eventId} {
      allow read: if resource.data.visibility == 'public'
                  || (request.auth != null && (
                       request.auth.token.email == 'jjun8647@gmail.com'
                       || exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email))
                     ));
      allow write: if request.auth != null && request.auth.token.email == 'jjun8647@gmail.com';
    }
    match /allowedUsers/{email} {
      allow read: if request.auth != null && request.auth.token.email == 'jjun8647@gmail.com';
      allow write: if request.auth != null && request.auth.token.email == 'jjun8647@gmail.com';
    }
    match /login_logs/{logId} {
      allow read: if request.auth != null && request.auth.token.email == 'jjun8647@gmail.com';
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;
    }
  }
}
