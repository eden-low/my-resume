rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null && request.auth.token.email == 'jjun8647@gmail.com';
    }
    function isFriend() {
      return request.auth != null
             && exists(/databases/$(database)/documents/friends/$(request.auth.token.email));
    }
    // Who may create their own private content (own expenses/journal/photos/etc.) —
    // the owner, or anyone the owner has approved into the friends whitelist.
    function canParticipate() {
      return isOwner() || isFriend();
    }
    // v3.2: mutual-consent friend graph (friend_requests/friendships below) — distinct from the
    // legacy isFriend() whitelist role-check above (kept a different name to avoid shadowing it).
    // True once `ownerUid` has accepted the caller into friendships/{ownerUid}/friends/{caller}.
    function isAcceptedFriend(ownerUid) {
      return request.auth != null
             && exists(/databases/$(database)/documents/friendships/$(ownerUid)/friends/$(request.auth.uid));
    }
    function isMineOrPublic(data) {
      return request.auth != null && (
        data.uid == request.auth.uid
        || data.visibility == 'public'
        || (data.visibility == 'connections' && isAcceptedFriend(data.uid))
      );
    }
    // Same as isMineOrPublic, plus a fallback to the pre-v2.0 `uploadedBy` field so photos
    // created before the `uid` rename still read/update correctly without a data migration.
    function isPhotoMineOrPublic(data) {
      return request.auth != null
             && (data.uid == request.auth.uid || data.uploadedBy == request.auth.uid
                 || data.visibility == 'public'
                 || (data.visibility == 'connections' && isAcceptedFriend(data.uid)));
    }
    function canReadPost(photoId) {
      let post = get(/databases/$(database)/documents/photos/$(photoId)).data;
      return isPhotoMineOrPublic(post);
    }

    // Always-private: financial data has no "public" story.
    match /expenses/{expenseId} {
      allow read, update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if canParticipate() && request.resource.data.uid == request.auth.uid;
    }

    // Always-private: personal targets have no "public" story, same shape as expenses.
    match /goals/{goalId} {
      allow read, update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if canParticipate() && request.resource.data.uid == request.auth.uid;
    }

    // Always-private (v2.9): messages sealed for the writer's own future self. Same
    // owner-only shape as goals/expenses — never readable via isMineOrPublic(), by design.
    match /time_capsules/{capsuleId} {
      allow read, update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if canParticipate() && request.resource.data.uid == request.auth.uid;
    }

    // Always-private (v2.9): one-per-day mood/note checkpoint. Doc ID is `${uid}_${dateKey}`
    // (enforced client-side, see index.html) so a same-day save is a merge, not a duplicate.
    match /daily_reflections/{reflectionId} {
      allow read, update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if canParticipate() && request.resource.data.uid == request.auth.uid;
    }

    match /journals/{journalId} {
      allow read: if isMineOrPublic(resource.data);
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if canParticipate() && request.resource.data.uid == request.auth.uid;
    }

    match /life_events/{eventId} {
      allow read: if isMineOrPublic(resource.data);
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if canParticipate() && request.resource.data.uid == request.auth.uid;
    }

    match /habits/{habitId} {
      allow read: if isMineOrPublic(resource.data);
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if canParticipate() && request.resource.data.uid == request.auth.uid;
    }

    // Collections (v2.7): life-chapter containers that group existing records via
    // collectionId, same shape/visibility model as journals/life_events/habits.
    match /collections/{collectionId} {
      allow read: if isMineOrPublic(resource.data);
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if canParticipate() && request.resource.data.uid == request.auth.uid;
    }

    // Career CMS (resume.html, nav-labeled "Career"): unlike the rest of the app, this is not
    // a per-uid multi-tenant space — the page has always been about one person — so writes are
    // Owner-only, not canParticipate()-gated. HR/Friends/Viewers only ever read public items.
    match /career_experiences/{id} {
      allow read: if isMineOrPublic(resource.data);
      allow create, update, delete: if isOwner();
    }
    match /career_projects/{id} {
      allow read: if isMineOrPublic(resource.data);
      allow create, update, delete: if isOwner();
    }
    match /career_certificates/{id} {
      allow read: if isMineOrPublic(resource.data);
      allow create, update, delete: if isOwner();
    }
    match /career_awards/{id} {
      allow read: if isMineOrPublic(resource.data);
      allow create, update, delete: if isOwner();
    }

    match /photos/{photoId} {
      allow read: if isPhotoMineOrPublic(resource.data);
      allow update, delete: if request.auth != null
                             && (resource.data.uid == request.auth.uid || resource.data.uploadedBy == request.auth.uid);
      allow create: if canParticipate() && request.resource.data.uid == request.auth.uid;

      match /likes/{uid} {
        allow read: if canReadPost(photoId);
        allow write: if request.auth != null && request.auth.uid == uid && canReadPost(photoId);
      }
      match /comments/{commentId} {
        allow read: if canReadPost(photoId);
        allow create: if request.auth != null
                       && request.auth.uid == request.resource.data.uid
                       && canReadPost(photoId);
        allow update, delete: if false;
      }
      match /views/{viewId} {
        // Only the post's own owner needs to read view analytics for their post.
        allow read: if request.auth != null && get(/databases/$(database)/documents/photos/$(photoId)).data.uid == request.auth.uid;
        allow create: if request.auth != null
                       && request.auth.uid == request.resource.data.viewerUid
                       && canReadPost(photoId);
        allow update, delete: if false;
      }
    }

    // v3.2 Trusted Connections: mutual-consent friend-request graph, entirely separate from the
    // legacy owner/friend/viewer role whitelist (`friends/{email}` below). Every write here is
    // scoped to the caller's own uid path segment — no transactions, no cross-uid writes ever
    // required (see dashboard.js's reconcileFriendships() for how the acceptor's counterpart
    // creates their own mirror lazily on next load).
    match /friend_requests/{toUid}/incoming/{fromUid} {
      allow read: if request.auth != null && (request.auth.uid == toUid || request.auth.uid == fromUid);
      allow create: if request.auth != null && request.auth.uid == fromUid && fromUid != toUid
                    && request.resource.data.fromUid == fromUid
                    && request.resource.data.toUid == toUid
                    && request.resource.data.status == 'pending';
      allow update: if request.auth != null && (
        (request.auth.uid == toUid && resource.data.status == 'pending'
          && request.resource.data.status in ['accepted', 'declined'])
        || (request.auth.uid == fromUid && resource.data.status == 'pending'
          && request.resource.data.status == 'cancelled')
        // Re-send after a decline/cancel reuses the same doc (Firestore's create rule only
        // fires when no doc exists yet), so the original sender may reset it back to pending.
        || (request.auth.uid == fromUid && resource.data.status in ['declined', 'cancelled']
          && request.resource.data.status == 'pending')
        // Re-send after a later unfriend: removeFriend() only deletes the friendships/ mirror
        // docs, never this request doc (per spec, user data is never deleted), so a former
        // friend's request can still read 'accepted' here -- the original sender may reset it
        // back to pending to request again.
        || (request.auth.uid == fromUid && resource.data.status == 'accepted'
          && request.resource.data.status == 'pending')
      );
      allow delete: if false;
    }

    match /friendships/{uid}/friends/{friendUid} {
      allow read: if request.auth != null && (request.auth.uid == uid || request.auth.uid == friendUid);
      // Only creatable as part of an accepted friend_requests doc between the same two people
      // (checked in either direction, since either side's client may be the one writing its own
      // mirror) — this is what stops anyone from freely adding themselves as a friend.
      allow create: if request.auth != null && request.auth.uid == uid
                    && request.resource.data.friendUid == friendUid && (
        (exists(/databases/$(database)/documents/friend_requests/$(uid)/incoming/$(friendUid))
          && get(/databases/$(database)/documents/friend_requests/$(uid)/incoming/$(friendUid)).data.status == 'accepted')
        || (exists(/databases/$(database)/documents/friend_requests/$(friendUid)/incoming/$(uid))
          && get(/databases/$(database)/documents/friend_requests/$(friendUid)/incoming/$(uid)).data.status == 'accepted')
      );
      allow update: if false;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Whitelist of approved friends, keyed by lowercase email (owner can approve someone
    // before they've ever signed in — a uid wouldn't exist yet at that point).
    match /friends/{email} {
      allow read: if isOwner() || (request.auth != null && request.auth.token.email == email);
      allow write: if isOwner();
    }

    // Lightweight directory doc per signed-in user, upserted on every login — powers
    // "search other users' public content." Holds no private data.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid && request.resource.data.uid == uid;
    }

    // Reservation doc per @username, doc ID = the lowercase handle itself — "first writer
    // wins" comes for free from Firestore's create-vs-update distinction (the `allow create`
    // rule only ever fires when no doc with that ID exists yet; a rename deletes the old
    // reservation and creates a new one, it never updates one in place).
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /login_logs/{logId} {
      allow read: if isOwner();
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;
    }

    // Each user reads/marks-read only their own notifications; almost every notification is
    // still self-written by whoever's client observed the triggering condition — see the one
    // cross-user exception (friend_request/friend_accepted) in the create rule below.
    match /notifications/{notificationId} {
      allow read, update: if request.auth != null && resource.data.uid == request.auth.uid;
      // v3.2: a friend_request/friend_accepted notification is the one exception to "always
      // self-written" — the sender writes directly into the recipient's inbox, self-attested via
      // fromUid == caller (no cross-user data leak beyond what the friend-request flow already
      // exposes: display name/username/photo, never email).
      allow create: if request.auth != null && (
        request.auth.uid == request.resource.data.uid
        || (request.resource.data.type in ['friend_request', 'friend_accepted']
            && request.resource.data.fromUid == request.auth.uid)
      );
      allow delete: if false;
    }
  }
}
