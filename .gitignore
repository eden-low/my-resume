.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
node_modules/

# Generated Netlify publish output (scripts/build-site.js) — reproducible from source on every
# deploy, never hand-edited, never committed.
/site/

# Generated Tailwind CSS output (tailwind.config.js/tailwind-input.css are the tracked source) —
# rebuilt by `npm run build:css` on every build, never hand-edited, never committed.
/tailwind.generated.css

# Generated Deploy Preview origin snapshot for netlify/functions/anilist.js (scripts/generate-
# deploy-origin.js) — not a secret (an https URL), rebuilt by `npm run build` on every build,
# never hand-edited, never committed.
/netlify/functions/lib/deploy-origin.generated.json

# Environment / secrets (Netlify Functions prep) — never commit real values.
# Production secrets belong in Netlify Project configuration -> Environment variables,
# not in any file in this repo. See .env.example for the documented variable names.
.env
.env.*
!.env.example
*.local

# Netlify CLI local state (deploy cache, local function logs) — never needed in git.
.netlify/

# Firebase Admin / service-account credentials — this project only ever uses the public
# client-side Firebase Web config (firebase-init.js), never Admin SDK credentials in-repo.
service-account*.json
firebase-adminsdk-*.json
*firebase-adminsdk*.json
